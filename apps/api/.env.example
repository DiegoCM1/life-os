# FastAPI backend (Railway) — copy to .env for local dev, set in Railway for prod.

# Supabase Postgres connection string (Project Settings → Database → Connection string).
# Use the session pooler URI on Railway (IPv4).
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# The single shared secret. Must equal API_SECRET in the web app's env.
SHARED_SECRET=SHARED_SECRET

# Notion integration (read-only). Share the applications database with the integration.
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Property names inside the applications database:
NOTION_DATE_PROP=Fecha
NOTION_STATUS_PROP=Status
NOTION_TIER_PROP=Tier
